import os
import json
from pathlib import Path
from typing import List, Optional
from prometheus.core.models import Paper

class PaperIngestionEngine:
    """Handles loading and normalizing raw research paper inputs into core Paper objects."""
    
    def __init__(self, data_dir: Path):
        self.data_dir = Path(data_dir)
        # Ensure the ingestion directory exists
        self.data_dir.mkdir(parents=True, exist_ok=True)

    def ingest_single_json(self, file_path: Path) -> Paper:
        """Reads a structured JSON metadata/text file and converts it into a Paper instance."""
        if not os.path.exists(file_path):
            raise FileNotFoundError(f"Target paper file not found at: {file_path}")
            
        with open(file_path, "r", encoding="utf-8") as f:
            data = json.load(f)
            
        # Pydantic validates types automatically upon instantiation
        paper = Paper(
            title=data["title"],
            authors=data.get("authors", []),
            doi=data.get("doi"),
            publication_year=data.get("publication_year"),
            abstract=data.get("abstract"),
            raw_text_source=str(file_path.resolve())
        )
        return paper

    def ingest_directory(self) -> List[Paper]:
        """Scans the designated data directory and processes all available .json papers."""
        ingested_papers = []
        # Walk through the directory for target files
        for file in self.data_dir.glob("*.json"):
            try:
                paper_obj = self.ingest_single_json(file)
                ingested_papers.append(paper_obj)
            except Exception as e:
                # Log the error safely so one corrupted paper doesn't crash the pipeline
                print(f"Skipping corrupt paper file {file.name}: {str(e)}")
                
        return ingested_papers
